│                                                                              │
│    const renderStatusBadge = (label: string, tone: 'success' | 'neutral' |   │
│  'danger' | 'warning') => (                                                  │
│      <View                                                                   │
│        style={[                                                              │
│          styles.statusBadge,                                                 │
