│  style={styles.headerSubtitle}>{subtitle}</Text>}                            │
│        </View>                                                               │
│        <View style={styles.headerSpacer} />                                  │
│      </View>                                                                 │
│    );                                                                        │
│                                                                              │
│    const renderFieldRows = (fields: Array<{ label: string; value: string     │
│  }>) => (                                                                    │
│      <BlurView intensity={24} tint="dark" style={styles.detailsBlock}>       │
│        {fields.map((field, index) => (                                       │
│          <View                                                               │
│            key={`${field.label}-${index}`}                                   │
│            style={[styles.detailRow, index !== fields.length - 1 &&          │
│  styles.detailRowBorder]}                                                    │
│          >                                                                   │
│            <Text style={styles.detailLabel}>{field.label}</Text>             │
│            <Text style={styles.detailValue}>{field.value}</Text>             │
│          </View>                                                             │
│        ))}                                                                   │
│      </BlurView>                                                             │
│    );                                                                        │
│                                                                              │
│    const renderStatusBadge = (label: string, tone: 'success' | 'neutral' |   │
