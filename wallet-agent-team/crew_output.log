│      const now = Date.now();                                                 │
│                                                                              │
│      if (duplicateLockRef.current === normalized) {                          │
│        setFailureState('DUPLICATE_SCAN', 'This QR code was already           │
│  scanned.');                                                                 │
│        return;                                                               │
│      }                                                                       │
│                                                                              │
│      if (lastScanRef.current && lastScanRef.current.data === normalized &&   │
│  now - lastScanRef.current.timestamp < 4000) {                               │
│        setFailureState('DUPLICATE_SCAN', 'This QR code was already           │
│  scanned.');                                                                 │
│        return;                                                               │
│      }                                                                       │
│                                                                              │
