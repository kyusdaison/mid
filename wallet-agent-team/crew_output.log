│          statusParam === 'Verified' ||                                       │
│          statusParam === 'Active' ||                                         │
│          statusParam === 'Expired' ||                                        │
│          statusParam === 'Revoked' ||                                        │
│          statusParam === 'Failed'                                            │
│            ? statusParam                                                     │
│            : 'Valid Request';                                                │
│                                                                              │
