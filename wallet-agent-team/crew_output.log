│  ## 6. 核心类型设计                                                          │
│                                                                              │
│  建议在 `src/features/verify/types.ts` 中定义以下结构。                      │
│                                                                              │
│  ## 6.1 流程状态                                                             │
│  ```ts                                                                       │
│  export type VerifyFlowState =                                               │
│    | 'SCANNING'                                                              │
│    | 'PROCESSING_SCAN'                                                       │
│    | 'READY_TO_PRESENT'                                                      │
│    | 'PRESENTING'                                                            │
│    | 'SUCCESS'                                                               │
│    | 'FAILURE';                                                              │
│  ```                                                                         │
│                                                                              │
│  ## 6.2 失败原因                                                             │
│  ```ts                                                                       │
│  export type VerifyFailureCode =                                             │
│    | 'INVALID_CODE'                                                          │
│    | 'REQUEST_UNREADABLE'                                                    │
│    | 'CREDENTIAL_UNAVAILABLE'                                                │
│    | 'CREDENTIAL_EXPIRED'                                                    │
│    | 'VERIFICATION_FAILED'                                                   │
│    | 'CONNECTION_REQUIRED'                                                   │
│    | 'CAMERA_PERMISSION_DENIED';                                             │
│  ```                                                                         │
│                                                                              │
│  ## 6.3 扫码请求模型                                                         │
│  ```ts                                                                       │
│  export interface VerificationRequest {                                      │
│    raw: string;                                                              │
│    scheme: 'fcid';                                                           │
│    requesterName?: string;                                                   │
│    requesterId?: string;                                                     │
│    purpose?: string;                                                         │
│    requestedFields: string[];                                                │
│    credentialType?: string;                                                  │
│    requestId?: string;                                                       │
│    expiresAt?: string;                                                       │
│    registry?: string;                                                        │
│  }                                                                           │
│  ```                                                                         │
│                                                                              │
│  ## 6.4 凭证预览模型                                                         │
│  ```ts                                                                       │
│  export interface CredentialPreview {                                        │
│    issuer: string;                                                           │
│    credentialType: string;                                                   │
│    holderName?: string;                                                      │
│    credentialId?: string;                                                    │
│    expirationDate: string;                                                   │
│    status: 'Verified' | 'Active' | 'Expired' | 'Revoked' | 'Unknown';        │
│  }                                                                           │
│  ```                                                                         │
│                                                                              │
│  ## 6.5 共享字段模型                                                         │
│  ```ts                                                                       │
│  export interface ShareableField {                                           │
│    key: string;                                                              │
│    label: string;                                                            │
│    value: string;                                                            │
│    sensitivity?: 'low' | 'medium' | 'high';                                  │
│    required: boolean;                                                        │
│  }                                                                           │
│  ```                                                                         │
│                                                                              │
│  ## 6.6 提交载荷模型                                                         │
│  ```ts                                                                       │
│  export interface CredentialPresentationPayload {                            │
│    requestId?: string;                                                       │
│    requesterId?: string;                                                     │
│    fields: Array<{                                                           │
│      key: string;                                                            │
│      value: string;                                                          │
│    }>;                                                                       │
│  }                                                                           │
│  ```                                                                         │
│                                                                              │
│  ---                                                                         │
│                                                                              │
│  ## 7. 数据流设计                                                            │
│                                                                              │
│  ## 7.1 总体数据流                                                           │
│                                                                              │
│  ```text                                                                     │
│  Camera Scan                                                                 │
│    -> parse request                                                          │
│    -> normalize request                                                      │
│    -> validate request                                                       │
│    -> match local credential                                                 │
│    -> build preview model                                                    │
│    -> build shareable fields                                                 │
│    -> render READY_TO_PRESENT                                                │
│    -> user confirms                                                          │
│    -> build final presentation payload                                       │
│    -> submit                                                                 │
│    -> success / failure                                                      │
│  ```                                                                         │
│                                                                              │
│  ## 7.2 详细步骤                                                             │
│                                                                              │
│  ### Step 1: 扫码                                                            │
│  `VerifyScannerPanel` 只负责采集扫码结果：                                   │
│  - 输出 `rawQrData`                                                          │
│                                                                              │
│  ### Step 2: 解析请求                                                        │
│  `useVerifyFlow` 调用 `verifyMappers.parseVerificationRequest(rawQrData)`    │
│                                                                              │
│  输出：                                                                      │
│  - `VerificationRequest`                                                     │
│  - 或失败：`INVALID_CODE` / `REQUEST_UNREADABLE`                             │
│                                                                              │
│  ### Step 3: 匹配本地凭证                                                    │
│  `useVerifyFlow` 调用本地 identity / wallet 数据源，查找可满足的凭证。       │
│                                                                              │
│  输出：                                                                      │
│  - `CredentialPreview`                                                       │
│  - 或失败：`CREDENTIAL_UNAVAILABLE` / `CREDENTIAL_EXPIRED`                   │
│                                                                              │
│  ### Step 4: 构造共享字段                                                    │
│  `verifyMappers.buildShareableFields(request, credential)`                   │
│                                                                              │
│  输出：                                                                      │
│  - `ShareableField[]`                                                        │
│                                                                              │
│  要求：                                                                      │
│  - 仅按请求目的构造                                                          │
│  - 默认最小必要披露                                                          │
│  - 该结果直接驱动 `FieldsToSharePanel`                                       │
│                                                                              │
│  ### Step 5: 进入 READY_TO_PRESENT                                           │
│  页面展示：                                                                  │
│  - `CredentialRequestHeader`                                                 │
│  - `CredentialPreviewCard`                                                   │
│  - `FieldsToSharePanel`                                                      │
│  - `VerifyActionBar`                                                         │
│                                                                              │
│  ### Step 6: 用户同意                                                        │
│  点击 `Present Credential` 后：                                              │
│  - 由 `useVerifyFlow` 调用 `verifyService.buildPresentationPayload()`        │
│  - payload 只能来自 `ShareableField[]`                                       │
│  - 不允许另行拼接额外字段                                                    │
│                                                                              │
│  ### Step 7: 提交                                                            │
│  `verifyService.presentCredential(payload)`                                  │
│                                                                              │
│  输出：                                                                      │
│  - 成功 -> `SUCCESS`                                                         │
│  - 失败 -> `VERIFICATION_FAILED` / `CONNECTION_REQUIRED`                     │
│                                                                              │
│  ---                                                                         │
│                                                                              │
│  ## 8. 状态管理集成方案                                                      │
│                                                                              │
│  ## 8.1 推荐方案                                                             │
│  使用 **页面级 hook + 现有 store 读取本地身份数据** 的组合方式：             │
│                                                                              │
│  - **流程状态**：放在 `useVerifyFlow`                                        │
│  - **本地身份 / 钱包数据**：继续来自 `walletStore` 或相关 context            │
│  - **不建议把 Verify 全流程直接塞进全局 store**                              │
│                                                                              │
│  原因：                                                                      │
│  1. Verify 是短生命周期流程                                                  │
│  2. 扫码与提交状态属于页面临时状态                                           │
│  3. 全局 store 会放大流程复杂度                                              │
│  4. 页面 hook 更容易 reset、测试、隔离副作用                                 │
│                                                                              │
│  ## 8.2 `useVerifyFlow` 返回结构建议                                         │
│  ```ts                                                                       │
│  {                                                                           │
│    flowState,                                                                │
│    failure,                                                                  │
│    request,                                                                  │
│    preview,                                                                  │
│    shareableFields,                                                          │
│    canPresent,                                                               │
│    isBusy,                                                                   │
│    scanHint,                                                                 │
│    onScan,                                                                   │
│    onPresent,                                                                │
│    onCancel,                                                                 │
│    onRetry,                                                                  │
│    onReset,                                                                  │
│    onRequestCameraPermission,                                                │
│  }                                                                           │
│  ```                                                                         │
│                                                                              │
│  ## 8.3 与 `walletStore` 的集成                                              │
│  `useVerifyFlow` 内部从 `walletStore` 或 identity context                    │
│  获取本地凭证相关信息，例如：                                                │
│  - fcdid                                                                     │
│  - holder name                                                               │
│  - residency id                                                              │
│  - issuer                                                                    │
│  - credential status                                                         │
│  - expiry                                                                    │
│                                                                              │
│  但这些原始数据不直接下发给页面。                                            │
│  必须经过：                                                                  │
│  - preview mapper                                                            │
│  - share field mapper                                                        │
│                                                                              │
│  两个出口分别派生，防止 UI 与 payload 混用。                                 │
│                                                                              │
│  ---                                                                         │
│                                                                              │
