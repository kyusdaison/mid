│            state: 'FAILURE' as VerifyFlowState,                              │
│            badge: 'Failed',                                                  │
│            title: 'Invalid Credential',                                      │
│            subtitle: 'Not a recognized FCDID',                               │
│            details: 'Invalid Credential — Not a recognized FCDID',           │
│            guidance: 'Try again with a valid MID-compatible verification     │
│  code.',                                                                     │
│            primary: 'Scan Again',                                            │
│            secondary: 'Back',                                                │
